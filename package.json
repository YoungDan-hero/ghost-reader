{
  "name": "ghost-reader",
  "productName": "GhostReader",
  "version": "1.0.0",
  "description": "A ghost-mode TXT reader — float your novel as bare text on any screen.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dmg": "electron-builder --mac dmg",
    "win": "electron-builder --win nsis --x64",
    "all": "electron-builder --mac dmg --win nsis --arm64 --x64"
  },
  "author": "yangdan",
  "license": "MIT",
  "devDependencies": {
    "electron": "31.0.0",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.yangdan.ghostreader",
    "productName": "GhostReader",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "mac": {
      "icon": "build/GhostReader.icns",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "dir",
          "arch": ["arm64"]
        }
      ],
      "identity": null
    },
    "dmg": {
      "title": "GhostReader"
    },
    "win": {
      "icon": "build/GhostReader.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/GhostReader.ico",
      "uninstallerIcon": "build/GhostReader.ico"
    }
  }
}
